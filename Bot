# --- SPAM WORKER (per token, fixed delay, rate limit sleep) ---
def spam_worker_per_token(c_id, target_mention, token, stop_event):
    while not stop_event.is_set():
        msg_template = random.choice(SPAM_MESSAGES)
        msg = msg_template.replace("##𝗗ʀᴀ𝗩ɪ𝗢ɴ#𝗩ɪ𝗗ʜ𝗔ʏᴀ𝗞", target_mention)
        msg = msg.replace("𝗗ʀᴀ𝗩ɪ𝗢ɴ#𝗩ɪ𝗗ʜ𝗔ʏᴀ𝗞", target_mention)
        response = send_msg(c_id, msg, token=token)
        # If rate limited, we already slept inside send_msg; just continue the normal delay.
        # Sleep SPAM_DELAY (0.1s) but break it into small chunks to stop quickly.
        for _ in range(int(SPAM_DELAY * 10)):
            if stop_event.is_set():
                return
            time.sleep(0.1)

